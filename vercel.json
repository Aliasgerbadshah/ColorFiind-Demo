function generateCategoryPalettes(category,count){
const usedNames = new Set();
const usedSignatures = new Set();
const recipes = paletteRecipes[category];
const output = [];
let attempt = 0;

while(output.length < count && attempt < count * 8){
const i = attempt;
const recipeIndex = i % recipes.length;
const cycle = Math.floor(i / recipes.length);
const hue = (recipeOffset[category] + (cycle * 137.508) + (recipeIndex * 47) + (seeded(i + category.length) * 26)) % 360;
let colors = recipes[recipeIndex](hue);
let signature = paletteSignature(colors);

/* If a generated palette falls into an already-used visual bucket, rotate strongly. */
let shiftTry = 0;
while(usedSignatures.has(signature) && shiftTry < 12){
const shiftedHue = (hue + 31 + shiftTry * 19) % 360;
colors = recipes[(recipeIndex + shiftTry) % recipes.length](shiftedHue);
signature = paletteSignature(colors);
shiftTry++;
}

if(!usedSignatures.has(signature)){
usedSignatures.add(signature);
const name = makeName(category,output.length,usedNames);
output.push({
name,
category,
concept:`${category.toLowerCase()} recipe ${recipeIndex} hue ${Math.round(hue/10)*10}`,
likes:0,
slug:slugify(name),
colors
});
}
attempt++;
}

return output;
}

function mixPalettesByCategory(data){
const groups = {};
categories.forEach(category=>groups[category]=data.filter(p=>p.category===category));
const mixed = [];
let added = true;
while(added){
added = false;
categories.forEach(category=>{
if(groups[category].length){
mixed.push(groups[category].shift());
added = true;
}
});
}
return mixed;
}

function buildPalettes(){
const all = [];
categories.forEach(category=>{
all.push(...generateCategoryPalettes(category,PALETTES_PER_CATEGORY));
});
return mixPalettesByCategory(all);
}

const basePalettes = buildPalettes();

