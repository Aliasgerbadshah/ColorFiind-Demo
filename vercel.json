<div class="preview-menu"><div class="category" onclick="filterCategory('Neon',this)">Neon</div><span class="preview-card"><span class="preview-palette"><span style="background:#0F172A"></span><span style="background:#00F5D4"></span><span style="background:#F15BB5"></span><span style="background:#9B5DE5"></span></span></span></div>
<div class="preview-menu"><div class="category" onclick="filterCategory('Dark',this)">Dark</div><span class="preview-card"><span class="preview-palette"><span style="background:#081C15"></span><span style="background:#1B4332"></span><span style="background:#2D6A4F"></span><span style="background:#95D5B2"></span></span></span></div>
<div class="preview-menu"><div class="category" onclick="filterCategory('Light',this)">Light</div><span class="preview-card"><span class="preview-palette"><span style="background:#FFFFFF"></span><span style="background:#F8F9FA"></span><span style="background:#E9ECEF"></span><span style="background:#DEE2E6"></span></span></span></div>
</div>

<div class="divider"></div>
<div class="categories">
<div class="category" style="font-weight:700;color:var(--text);cursor:default">Seasons</div>
<div class="season-menu"><a class="category season-parent season-trigger" href="/season/autumn">Autumn</a><div class="season-flyout"><div class="flyout-title">Autumn</div><span class="season-preview-square"><span style="background:#D8A67D"></span><span style="background:#B78B63"></span><span style="background:#8A8F5A"></span><span style="background:#CDBB99"></span></span><a class="flyout-item" href="/season/autumn/soft-autumn-color-palette"><span class="mini-palette"><span style="background:#D8A67D"></span><span style="background:#B78B63"></span><span style="background:#8A8F5A"></span><span style="background:#CDBB99"></span></span>Soft Autumn</a><a class="flyout-item" href="/season/autumn/warm-autumn-color-palette"><span class="mini-palette"><span style="background:#C76F2D"></span><span style="background:#D99A3D"></span><span style="background:#B88746"></span><span style="background:#8A7A2D"></span></span>Warm Autumn</a><a class="flyout-item" href="/season/autumn/deep-autumn-color-palette"><span class="mini-palette"><span style="background:#3B2416"></span><span style="background:#7A3E22"></span><span style="background:#9B5A2E"></span><span style="background:#6F6B2F"></span></span>Deep Autumn</a><a class="flyout-item" href="/season/autumn/dark-autumn-color-palette"><span class="mini-palette"><span style="background:#2B1A12"></span><span style="background:#4B2E1F"></span><span style="background:#7C3F1D"></span><span style="background:#A65F2B"></span></span>Dark Autumn</a><a class="flyout-item" href="/season/autumn/true-autumn-color-palette"><span class="mini-palette"><span style="background:#A44A2A"></span><span style="background:#BC6C25"></span><span style="background:#DDA15E"></span><span style="background:#606C38"></span></span>True Autumn</a></div></div>
<div class="season-menu"><a class="category season-parent season-trigger" href="/season/summer">Summer</a><div class="season-flyout"><div class="flyout-title">Summer</div><span class="season-preview-square"><span style="background:#A9B7C9"></span><span style="background:#C7A6B8"></span><span style="background:#D8C7D8"></span><span style="background:#8FA1B3"></span></span><a class="flyout-item" href="/season/summer/soft-summer-color-palette"><span class="mini-palette"><span style="background:#A9B7C9"></span><span style="background:#C7A6B8"></span><span style="background:#D8C7D8"></span><span style="background:#8FA1B3"></span></span>Soft Summer</a><a class="flyout-item" href="/season/summer/light-summer-color-palette"><span class="mini-palette"><span style="background:#EAF4FF"></span><span style="background:#CFE8F3"></span><span style="background:#F6DDE8"></span><span style="background:#DCCEF2"></span></span>Light Summer</a><a class="flyout-item" href="/season/summer/true-summer-color-palette"><span class="mini-palette"><span style="background:#7D8FA3"></span><span style="background:#A7B6C8"></span><span style="background:#B995A9"></span><span style="background:#8D6A8E"></span></span>True Summer</a><a class="flyout-item" href="/season/summer/cool-summer-color-palette"><span class="mini-palette"><span style="background:#8EA7C2"></span><span style="background:#B7C9D9"></span><span style="background:#C9B6D3"></span><span style="background:#D7A9B9"></span></span>Cool Summer</a></div></div>
