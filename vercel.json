<script>
/* ==========================================
COLORFIIND V10 CORRECTED WITH V8 LOOK
========================================== */

/* ==========================================
COLORFIIND V12 LARGE CURATED-STYLE PALETTE ENGINE
Goal: 1000 palettes per category without tiny HEX-only variations.
Method:
- No simple random generation.
- Category-specific recipe groups.
- Golden-angle hue spacing for strong visual separation.
- Different palette structures/concepts per recipe.
- Name generator with real words, no numbers.
- Signature filter to avoid near-identical palette structures.
========================================== */

const categories = ["Pastel","Vintage","Luxury","Retro","Neon","Dark","Light"];
const PALETTES_PER_CATEGORY = 1000;

function clamp(value,min,max){
return Math.max(min,Math.min(max,value));
}

function seeded(seed){
const x = Math.sin(seed * 999.917) * 10000;
return x - Math.floor(x);
}

function pick(arr,seed){
return arr[Math.floor(seeded(seed) * arr.length) % arr.length];
}

function slugify(text){
return text.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'');
}

function hslToHex(h,s,l){
h = ((h % 360) + 360) % 360;
s = clamp(s,0,100) / 100;
l = clamp(l,0,100) / 100;
const k = n => (n + h / 30) % 12;
const a = s * Math.min(l,1-l);
const f = n => l - a * Math.max(-1,Math.min(k(n)-3,Math.min(9-k(n),1)));
const toHex = x => Math.round(255*x).toString(16).padStart(2,'0');
return `#${toHex(f(0))}${toHex(f(8))}${toHex(f(4))}`.toUpperCase();
}

function hexToRgb(hex){
const clean = hex.replace('#','');
return {
r:parseInt(clean.slice(0,2),16) / 255,
g:parseInt(clean.slice(2,4),16) / 255,
b:parseInt(clean.slice(4,6),16) / 255
};
}

function rgbToHsl(hex){
let {r,g,b} = hexToRgb(hex);
const max = Math.max(r,g,b);
const min = Math.min(r,g,b);
let h = 0;
let s = 0;
const l = (max + min) / 2;
if(max !== min){
const d = max - min;
s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
switch(max){
case r: h = (g - b) / d + (g < b ? 6 : 0); break;
case g: h = (b - r) / d + 2; break;
case b: h = (r - g) / d + 4; break;
}
h *= 60;
}
return {h,s,l};
}

function paletteSignature(colors){
/* sorted HSL buckets catch palettes that only differ by very small HEX tweaks */
return colors.map(color=>{
const hsl = rgbToHsl(color);
const hb = Math.round(hsl.h / 3);
const sb = Math.round(hsl.s * 20);
const lb = Math.round(hsl.l * 20);
return `${hb}:${sb}:${lb}`;
}).sort().join('|');
}

function pivotRgb(n){
return n > 0.04045 ? Math.pow((n + 0.055) / 1.055, 2.4) : n / 12.92;
}

function pivotXyz(n){
return n > 0.008856 ? Math.cbrt(n) : (7.787 * n) + (16 / 116);
}

function hexToLab(hex){
const rgb = hexToRgb(hex);
const r = pivotRgb(rgb.r);
const g = pivotRgb(rgb.g);
const b = pivotRgb(rgb.b);
let x = (r * 0.4124 + g * 0.3576 + b * 0.1805) / 0.95047;
let y = (r * 0.2126 + g * 0.7152 + b * 0.0722) / 1.00000;
let z = (r * 0.0193 + g * 0.1192 + b * 0.9505) / 1.08883;
x = pivotXyz(x);
y = pivotXyz(y);
z = pivotXyz(z);
return {l:(116 * y) - 16,a:500 * (x - y),b:200 * (y - z)};
}

function deltaE(hex1,hex2){
const a = hexToLab(hex1);
const b = hexToLab(hex2);
return Math.sqrt(Math.pow(a.l-b.l,2)+Math.pow(a.a-b.a,2)+Math.pow(a.b-b.b,2));
}

function sortedByHue(colors){
return [...colors].sort((a,b)=>rgbToHsl(a).h-rgbToHsl(b).h);
}

function sortedByLightness(colors){
return [...colors].sort((a,b)=>rgbToHsl(a).l-rgbToHsl(b).l);
}

function averageDelta(colorsA,colorsB){
let total = 0;
for(let i=0;i<4;i++) total += deltaE(colorsA[i],colorsB[i]);
return total / 4;
}

function paletteVisualDistance(p1,p2){
const direct = averageDelta(p1.colors,p2.colors);
const reversed = averageDelta(p1.colors,[...p2.colors].reverse());
const hueSorted = averageDelta(sortedByHue(p1.colors),sortedByHue(p2.colors));
const lightSorted = averageDelta(sortedByLightness(p1.colors),sortedByLightness(p2.colors));
return Math.min(direct,reversed,hueSorted,lightSorted);
}

function hueDistance(a,b){
const diff = Math.abs(a-b) % 360;
return Math.min(diff,360-diff) / 180;
}

function paletteFeatures(palette){
if(!palette._features){
palette._features = sortedByHue(palette.colors).map(color=>rgbToHsl(color));
}
return palette._features;
}

function fastPaletteDistance(p1,p2){
const a = paletteFeatures(p1);
const b = paletteFeatures(p2);
let total = 0;
for(let i=0;i<4;i++){
total += hueDistance(a[i].h,b[i].h) * 42;
total += Math.abs(a[i].s-b[i].s) * 38;
total += Math.abs(a[i].l-b[i].l) * 52;
}
return total / 4;
}

function isPaletteTooSimilar(candidate,pool,threshold=13){
paletteFeatures(candidate);
return pool.some(existing => fastPaletteDistance(candidate,existing) < threshold);
}


