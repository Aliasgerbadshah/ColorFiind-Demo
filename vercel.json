<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>ColorFiind</title>
<link rel="icon" href="data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%20viewBox%3D%220%200%2064%2064%22%3E%3Cdefs%3E%3ClinearGradient%20id%3D%22g%22%20x1%3D%220%22%20y1%3D%220%22%20x2%3D%221%22%20y2%3D%221%22%3E%3Cstop%20offset%3D%220%22%20stop-color%3D%22%23ff4d6d%22/%3E%3Cstop%20offset%3D%220.25%22%20stop-color%3D%22%23ffd166%22/%3E%3Cstop%20offset%3D%220.5%22%20stop-color%3D%22%2306d6a0%22/%3E%3Cstop%20offset%3D%220.75%22%20stop-color%3D%22%23118ab2%22/%3E%3Cstop%20offset%3D%221%22%20stop-color%3D%22%239b5de5%22/%3E%3C/linearGradient%3E%3C/defs%3E%3Crect%20width%3D%2264%22%20height%3D%2264%22%20rx%3D%2218%22%20fill%3D%22%23ffffff%22/%3E%3Cpath%20d%3D%22M46.5%2043.4C42.8%2047.2%2037.8%2049%2032.2%2049%2021.6%2049%2014%2041.7%2014%2032.1S21.7%2015%2032.4%2015c5.8%200%2010.7%202%2014.1%205.6l-5.1%205.4c-2.4-2.6-5.3-3.8-8.6-3.8-6.1%200-10.3%204.1-10.3%209.9s4.2%209.9%2010.3%209.9c3.3%200%206.2-1.2%208.6-3.9l5.1%205.3z%22%20fill%3D%22url%28%23g%29%22/%3E%3C/svg%3E">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
:root{
--bg:#ffffff;
--card:#ffffff;
--text:#111111;
--muted:#777777;
--border:#ececec;
--hover:#f7f7f7;
--active:#efefef;
}

[data-theme="dark"]{
--bg:#111111;
--card:#1b1b1b;
--text:#ffffff;
--muted:#a1a1a1;
--border:#2b2b2b;
--hover:#222222;
--active:#2c2c2c;
}

*{
margin:0;
padding:0;
box-sizing:border-box;
}

html{
scroll-behavior:smooth;
}

body{
font-family:'Inter',system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
background:var(--bg);
color:var(--text);
overflow-x:hidden;
transition:.25s;
}

::-webkit-scrollbar{
width:8px;
}

::-webkit-scrollbar-thumb{
background:#d9d9d9;
border-radius:100px;
}

/* SIDEBAR - SAME V8 LOOK */
.sidebar{
position:fixed;
left:0;
top:0;
width:250px;
height:100vh;
background:var(--card);
border-right:1px solid var(--border);
padding:24px;
overflow-y:auto;
z-index:100;
}

.logo{
font-size:30px;
font-weight:800;
margin-bottom:16px;
display:inline-flex;
align-items:center;
gap:0;
letter-spacing:-1px;
text-decoration:none;
}

.logo span{
display:inline-block;
}

.brand-color .lc{color:#FF4D6D;}
.brand-color .lo1{color:#FFB703;}
.brand-color .ll{color:#06D6A0;}
.brand-color .lo2{color:#118AB2;}
.brand-color .lr{color:#9B5DE5;}
.brand-space{width:7px;}
.brand-fiind{color:#111111;}
[data-theme="dark"] .brand-fiind{color:#ffffff;}

.theme-toggle{
display:flex;
align-items:center;
justify-content:center;
padding:12px;
background:var(--hover);
border-radius:12px;
cursor:pointer;
font-size:14px;
font-weight:600;
margin-bottom:22px;
transition:.2s;
user-select:none;
}

.theme-toggle:hover{
transform:translateY(-2px);
}

.nav{
display:flex;
flex-direction:column;
gap:6px;
}

.nav-item{
display:flex;
align-items:center;
gap:12px;
padding:14px 16px;
border-radius:14px;
cursor:pointer;
transition:.2s;
font-size:15px;
font-weight:500;
color:var(--muted);
user-select:none;
}

.nav-item:hover{
background:var(--hover);
color:var(--text);
}

.nav-item.active{
background:var(--active);
color:var(--text);
}

.divider{
height:1px;
background:var(--border);
margin:20px 0;
}

.categories{
display:flex;
flex-direction:column;
}

.category{
padding:10px 0;
font-size:14px;
cursor:pointer;
color:var(--muted);
transition:.2s;
user-select:none;
}

.category:hover{
color:var(--text);
}

.category.active{
font-weight:600;
color:var(--text);
}

.season-parent{font-weight:400;color:var(--muted);margin-top:0;}
.sub-season{padding:7px 0 7px 14px;font-size:13px;color:var(--muted);display:block;}
.sub-season:hover{color:var(--text);}

.season-menu{position:relative;}
.season-trigger{display:block;}
.season-trigger-preview,.mini-palette,.season-preview-square{display:grid;grid-template-columns:repeat(4,1fr);overflow:hidden;border-radius:8px;flex-shrink:0;}
.season-trigger-preview{width:42px;height:18px;}
.mini-palette{width:58px;height:24px;}
.season-preview-square{width:100%;height:130px;border-radius:16px;margin-bottom:10px;}
.season-flyout{display:none;position:fixed;left:270px;top:var(--preview-top,120px);width:220px;background:var(--card);border:1px solid var(--border);border-radius:18px;box-shadow:0 18px 50px rgba(0,0,0,.18);padding:12px;z-index:2000;}
.season-menu:hover .season-flyout{display:block;}
.preview-menu{position:relative;}
.preview-card{display:none;position:fixed;left:270px;top:var(--preview-top,120px);transform:none;width:180px;height:182px;border-radius:14px;overflow:hidden;box-shadow:0 18px 50px rgba(0,0,0,.16);z-index:1900;border:1px solid var(--border);background:var(--card);pointer-events:none;}
.preview-card .preview-palette{height:100%;display:grid;grid-template-columns:repeat(4,1fr);}
.preview-menu:hover .preview-card{display:block;}
.flyout-title{font-size:14px;font-weight:800;margin-bottom:8px;color:var(--text);}
.flyout-item{display:flex;align-items:center;gap:10px;padding:9px;border-radius:12px;color:var(--muted);font-size:13px;font-weight:700;}
.flyout-item:hover{background:var(--hover);color:var(--text);}

/* MAIN - SAME V8 LOOK */
.main{
margin-left:250px;
padding:24px;
}

.topbar{
position:sticky;
top:0;
background:var(--bg);
padding-bottom:18px;
z-index:50;
}

.search{
width:100%;
padding:15px 18px;
border:1px solid var(--border);
border-radius:999px;
background:var(--card);
color:var(--text);
outline:none;
font-size:14px;
}

.search::placeholder{
color:var(--muted);
}


.results-meta{margin-top:10px;font-size:13px;font-weight:600;color:var(--muted)}.ad-slot{grid-column:1/-1;min-height:92px;border:1px dashed var(--border);border-radius:18px;background:linear-gradient(135deg,var(--hover),var(--card));color:var(--muted);display:flex;align-items:center;justify-content:center;text-align:center;font-size:13px;font-weight:700;letter-spacing:.2px;margin-bottom:24px}.grid .ad-slot{margin:0;min-height:120px}.copy-toast{position:fixed;left:50%;bottom:28px;transform:translate(-50%,20px);background:#111;color:#fff;padding:12px 16px;border-radius:999px;font-size:14px;font-weight:700;box-shadow:0 12px 40px rgba(0,0,0,.22);z-index:2000;opacity:0;pointer-events:none;transition:.25s}.copy-toast.show{opacity:1;transform:translate(-50%,0)}.copied-pulse{animation:copyPulse .55s ease}@keyframes copyPulse{0%{transform:scale(1)}45%{transform:scale(1.16)}100%{transform:scale(1)}}.sidebar-backdrop{display:none;position:fixed;inset:0;background:rgba(0,0,0,.35);z-index:90;opacity:0;transition:.25s}.sidebar-backdrop.show{display:block;opacity:1}

.grid{
display:grid;
grid-template-columns:repeat(4,1fr);
gap:24px;
}

/* CARD - SAME V8 LOOK */
.card{
cursor:pointer;
transform:translateY(0);
transition:.25s;
}

.card:hover{
transform:translateY(-4px);
}

.palette{
height:290px;
border-radius:18px;
overflow:hidden;
display:grid;
grid-template-columns:1fr 1fr 1fr 1fr;
transition:grid-template-columns .7s cubic-bezier(.25,.8,.25,1);
background:var(--hover);
}

.color{
display:flex;
align-items:center;
justify-content:center;
overflow:hidden;
position:relative;
}

.color span{
opacity:0;
transform:translateY(12px);
transition:.4s;
font-size:13px;
font-weight:700;
color:#fff;
mix-blend-mode:difference;
letter-spacing:.2px;
}

.color:hover span{
opacity:1;
transform:translateY(0);
}

/* V8 PERFECT 40% EXPANSION */
.palette:has(.c1:hover){
grid-template-columns:1.6fr .8fr .8fr .8fr;
}

.palette:has(.c2:hover){
grid-template-columns:.8fr 1.6fr .8fr .8fr;
}

.palette:has(.c3:hover){
grid-template-columns:.8fr .8fr 1.6fr .8fr;
}

.palette:has(.c4:hover){
grid-template-columns:.8fr .8fr .8fr 1.6fr;
}

.info{
padding-top:12px;
}

.name{
font-size:14px;
font-weight:600;
margin-bottom:8px;
}

.actions{
display:flex;
align-items:center;
gap:18px;
color:var(--text);
}

.actions span{
display:flex;
align-items:center;
gap:6px;
cursor:pointer;
transition:.2s;
font-size:14px;
color:var(--text);
}

.actions span:hover{
transform:scale(1.08);
}

.icon{
width:18px;
height:18px;
stroke:currentColor;
stroke-width:2;
fill:none;
}

.favorite.active .icon{
fill:currentColor;
}

.empty{
grid-column:1/-1;
padding:60px 20px;
text-align:center;
color:var(--muted);
font-size:14px;
font-weight:600;
}

/* LOADER */
#loader{
text-align:center;
padding:40px;
font-size:14px;
font-weight:600;
color:var(--muted);
display:none;
}

/* MOBILE */
.mobile-toggle{
display:none;
position:fixed;
left:15px;
top:15px;
z-index:999;
background:var(--card);
color:var(--text);
border:1px solid var(--border);
padding:10px 12px;
border-radius:10px;
cursor:pointer;
}

@media(max-width:1400px){
.grid{
grid-template-columns:repeat(3,1fr);
}
}

@media(max-width:1000px){
body.sidebar-open{overflow:hidden}.sidebar{transform:translateX(-100%);transition:.3s;box-shadow:20px 0 60px rgba(0,0,0,.18)}.sidebar.show{transform:translateX(0)}.mobile-toggle{display:block}.main{margin-left:0;padding:70px 16px 24px}.topbar{backdrop-filter:blur(14px)}.grid{grid-template-columns:repeat(2,1fr);gap:18px}.palette{height:240px}}

@media(max-width:700px){.grid{grid-template-columns:1fr;gap:22px}.palette{height:280px}.logo{font-size:28px}.search{padding:14px 16px}.copy-toast{width:calc(100% - 32px);text-align:center}}
</style>
</head>

<body>

