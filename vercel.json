const globalUsedNames = new Set();

function makeName(category,index,usedNames){
const words = nameWords[category];
const totalB = words.b.length;
const totalC = words.c.length;
let attempt = 0;

while(attempt < words.a.length * words.b.length * words.c.length){
const n = index + attempt;
const a = words.a[(n * 7 + category.length) % words.a.length];
const b = words.b[(Math.floor(n / words.a.length) * 11 + n) % totalB];
const c = words.c[(Math.floor(n / (words.a.length * totalB)) * 13 + n) % totalC];
const name = `${a} ${b} ${c}`;

if(!usedNames.has(name) && !globalUsedNames.has(name)){
usedNames.add(name);
globalUsedNames.add(name);
return name;
}
attempt++;
}

/* Very unlikely fallback. Still no numbers. */
const fallback = `${category} ${pick(words.a,index)} ${pick(words.b,index+9)} ${pick(words.c,index+19)} ${pick(words.c,index+29)}`;
usedNames.add(fallback);
globalUsedNames.add(fallback);
return fallback;
}

