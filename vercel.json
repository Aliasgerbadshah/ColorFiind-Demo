return style === 0
? [hslToHex(hue,42,7),hslToHex(hue+28,48,16),hslToHex(hue+76,52,31),hslToHex(hue+164,38,50)]
: [hslToHex(hue,55,10),hslToHex(hue+122,44,20),hslToHex(hue+210,48,36),hslToHex(hue+294,36,58)];
case "Light":
return style === 0
? [hslToHex(hue,28,97),hslToHex(hue+38,40,91),hslToHex(hue+94,45,78),hslToHex(hue+156,58,38)]
: [hslToHex(hue,18,96),hslToHex(hue+132,35,88),hslToHex(hue+218,48,74),hslToHex(hue+300,56,42)];
default:
return [hslToHex(hue,70,55),hslToHex(hue+60,70,60),hslToHex(hue+130,65,62),hslToHex(hue+210,60,64)];
}
}

function dailyPaletteName(seed,usedNames){
let attempt = 0;
while(attempt < 80){
const a = dailyNameA[(seed + attempt * 3) % dailyNameA.length];
const b = dailyNameB[(seed * 2 + attempt * 5) % dailyNameB.length];
const c = dailyNameC[(seed * 3 + attempt * 7) % dailyNameC.length];
const name = attempt % 2 === 0 ? `${a} ${b}` : `${a} ${b} ${c}`;
if(!usedNames.has(name)){
usedNames.add(name);
return name;
}
attempt++;
}
const fallback = `${dailyNameA[seed % dailyNameA.length]} ${dailyNameB[(seed+9) % dailyNameB.length]} ${dailyNameC[(seed+17) % dailyNameC.length]}`;
usedNames.add(fallback);
return fallback;
}

function scheduledDateTime(date,slot){
const item = dailyUploadSlots[slot];
const d = new Date(date);
d.setHours(item.hour,item.minute,0,0);
return d;
}

function generateDailyPalettes(){
const now = new Date();
const usedNames = new Set(basePalettes.map(p=>p.name));
const usedSlugs = new Set(basePalettes.map(p=>p.slug));
const usedSignatures = new Set(basePalettes.map(p=>paletteSignature(p.colors)));
const daily = [];
/* Use a diverse comparison sample for fast Vercel preview. Production Hostinger cron will check against full MySQL data. */
const comparisonPool = basePalettes.filter((_,index)=>index % 35 === 0);

/* Previous 45 days are already uploaded, so the site has a daily archive. */
for(let dayOffset=14; dayOffset>=0; dayOffset--){
const day = new Date(now);
day.setDate(now.getDate() - dayOffset);
const key = dateKey(day);
const palettesToday = (dailySeedFromDate(key,0) % 5 === 0) ? 4 : 3;

for(let slot=0; slot<palettesToday; slot++){
const uploadTime = scheduledDateTime(day,slot);
if(dayOffset === 0 && now < uploadTime) continue;
const baseSeed = dailySeedFromDate(key,slot);
let accepted = null;

for(let attempt=0; attempt<100; attempt++){
const seed = baseSeed + attempt * 23;
const category = dailyCategoryCycle[(seed + slot + attempt) % dailyCategoryCycle.length];
const colors = dailyPaletteColors(category,seed,attempt);
const signature = paletteSignature(colors);
if(usedSignatures.has(signature)) continue;

const name = dailyPaletteName(seed,usedNames);
let slug = slugify(name);
if(usedSlugs.has(slug)) slug = slugify(`${name} ${dailyNameC[(seed+attempt) % dailyNameC.length]}`);

const candidate = {
name,
category,
concept:`daily ${category.toLowerCase()} unique upload ${key}`,
likes:0,
slug,
colors,
source:'daily',
createdAt:uploadTime.toISOString()
};

/* Strict visual check: reject if it looks too close to any existing or daily palette. */
if(!isPaletteTooSimilar(candidate,comparisonPool,13)){
accepted = candidate;
usedSlugs.add(slug);
usedSignatures.add(signature);
break;
}
}

if(accepted){
daily.push(accepted);
comparisonPool.push(accepted);
}
}
}

return daily.sort((a,b)=>new Date(b.createdAt)-new Date(a.createdAt));
}

const dailyPalettes = generateDailyPalettes();
const palettes = [...dailyPalettes,...basePalettes];

/* Remove internal comparison features before exposing palettes to frontend/API. */
palettes.forEach(palette=>delete palette._features);

console.log('Daily demo palettes:',dailyPalettes.length);
console.log('Generated palette counts:',categories.reduce((acc,category)=>{
acc[category] = palettes.filter(p=>p.category===category).length;
return acc;
},{}));

/* Final safety checks */
const seenNames = new Set();
const seenColorSets = new Set();
palettes.forEach(p=>{
if(/\s+\d+$/.test(p.name)) console.warn('Numbered name found:',p.name);
if(seenNames.has(p.name)) console.warn('Duplicate name:',p.name);
seenNames.add(p.name);
const key = p.colors.join('|');
if(seenColorSets.has(key)) console.warn('Duplicate exact colors:',p.name);
seenColorSets.add(key);
});

/* APP STATE */

/*
GLOBAL LIKES API
For all visitors to share the same like counts, connect these endpoints on your backend:
GET  /api/likes
Response: { "palette-slug": 12, "another-slug": 5 }

POST /api/likes/:slug
Body: { visitorId: "unique-browser-id" }
Response: { "slug": "palette-slug", "count": 13 }

DELETE /api/likes/:slug
Body: { visitorId: "unique-browser-id" }
Response: { "slug": "palette-slug", "count": 12 }

Important: Backend should prevent the same visitorId from liking the same palette multiple times and should decrement on unlike.
*/
const API_BASE = '/api';
const LIKED_STORAGE_KEY = 'colorfiind-liked-palettes';
const VISITOR_STORAGE_KEY = 'colorfiind-visitor-id';

function getVisitorId(){
let visitorId = localStorage.getItem(VISITOR_STORAGE_KEY);
if(!visitorId){
visitorId = 'visitor-' + cryptoRandomId();
localStorage.setItem(VISITOR_STORAGE_KEY,visitorId);
}
return visitorId;
}

function cryptoRandomId(){
try{
const values = new Uint32Array(4);
crypto.getRandomValues(values);
return Array.from(values).map(v=>v.toString(36)).join('-');
}catch(e){
return Date.now().toString(36) + '-' + Math.random().toString(36).slice(2);
}
}

function getLikedPalettes(){
return JSON.parse(localStorage.getItem(LIKED_STORAGE_KEY) || '[]');
}

function setLikedPalettes(liked){
localStorage.setItem(LIKED_STORAGE_KEY,JSON.stringify(liked));
}

function applyLikeCounts(likeMap){
palettes.forEach(palette=>{
palette.likes = Number(likeMap[palette.slug] || 0);
});
}

async function loadGlobalLikes(){
try{
const response = await fetch(`${API_BASE}/likes`,{cache:'no-store'});
if(!response.ok) throw new Error('Unable to load likes');
const likeMap = await response.json();
applyLikeCounts(likeMap);
renderInfinite();
}catch(error){
console.warn('Global likes API not connected yet. Showing zero likes.',error);
applyLikeCounts({});
renderInfinite();
}
}

async function sendLikeToServer(slug){
const response = await fetch(`${API_BASE}/likes/${encodeURIComponent(slug)}`,{
method:'POST',
headers:{'Content-Type':'application/json'},
body:JSON.stringify({visitorId:getVisitorId()})
});
if(!response.ok) throw new Error('Unable to save like');
return response.json();
}

async function sendUnlikeToServer(slug){
const response = await fetch(`${API_BASE}/likes/${encodeURIComponent(slug)}`,{
method:'DELETE',
headers:{'Content-Type':'application/json'},
body:JSON.stringify({visitorId:getVisitorId()})
});
if(!response.ok) throw new Error('Unable to remove like');
return response.json();
}

let currentPalettes = [...palettes];
let currentPage = 1;
let itemsPerLoad = 24;
let isLoading = false;
let currentMode = 'all';

const grid = document.getElementById('grid');
const loader = document.getElementById('loader');
const searchInput = document.getElementById('search');
const resultsMeta = document.getElementById('resultsMeta');
const copyToast = document.getElementById('copyToast');

/* CARD TEMPLATE - SAME V8 ACTION STYLE */
function createPaletteCard(palette,index,active){
return `
<div class="card" data-slug="${palette.slug}" title="Open ${palette.name} palette page">
  <div class="palette">
    <div class="color c1" style="background:${palette.colors[0]}"><span>${palette.colors[0]}</span></div>
    <div class="color c2" style="background:${palette.colors[1]}"><span>${palette.colors[1]}</span></div>
    <div class="color c3" style="background:${palette.colors[2]}"><span>${palette.colors[2]}</span></div>
    <div class="color c4" style="background:${palette.colors[3]}"><span>${palette.colors[3]}</span></div>
  </div>
  <div class="info">
    <div class="name">${palette.name}</div>
    <div class="actions">
      <span class="favorite ${active ? 'active' : ''}" onclick="event.stopPropagation();likePalette('${palette.slug}')">
        <svg class="icon" viewBox="0 0 24 24"><path d="M12 21s-7-4.35-9.5-8C.5 10 .9 5.5 5 4c2.3-.8 4.2.2 5 1.5C10.8 4.2 12.7 3.2 15 4c4.1 1.5 4.5 6 2.5 9-2.5 3.65-9.5 8-9.5 8z"/></svg>
        ${palette.likes}
      </span>
      <span onclick="event.stopPropagation();copyLink('${palette.slug}',this)" title="Copy link">
        <svg class="icon" viewBox="0 0 24 24"><path d="M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1"/><path d="M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1"/></svg>
      </span>
      <span onclick="event.stopPropagation();copyColors(${index},this)" title="Copy colors">
        <svg class="icon" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      </span>
      <span onclick="event.stopPropagation();downloadPaletteImage(${index},this)" title="Download palette PNG">
        ⬇
      </span>
    </div>
  </div>
</div>`;
}

function createAdCard(position){return `<div class="ad-slot">Advertisement Space — native palette grid ad #${position}</div>`;}

function updateResultsMeta(){const total=currentPalettes.length;const visible=Math.min(currentPage*itemsPerLoad,total);const label=currentMode==='favorites'?'collection palettes':'palettes';resultsMeta.textContent=`Showing ${visible.toLocaleString()} of ${total.toLocaleString()} ${label}`;}

function renderInfinite(){
const visiblePalettes = currentPalettes.slice(0,currentPage * itemsPerLoad);
const likedPalettes = getLikedPalettes();
let html = '';

visiblePalettes.forEach((palette,index)=>{
const active = likedPalettes.includes(palette.slug);
html += createPaletteCard(palette,index,active);
if((index + 1) % 32 === 0 && index + 1 < visiblePalettes.length){
html += createAdCard(Math.floor((index + 1) / 32));
}
});

if(html === ''){
html = '<div class="empty">No palettes found.</div>';
}

grid.innerHTML = html;
updateResultsMeta();
}

async function writeClipboard(text){
try{
await navigator.clipboard.writeText(text);
return true;
}catch(e){
const textarea = document.createElement('textarea');
textarea.value = text;
textarea.style.position = 'fixed';
textarea.style.left = '-9999px';
document.body.appendChild(textarea);
textarea.select();
const ok = document.execCommand('copy');
document.body.removeChild(textarea);
return ok;
}
}

async function copyColors(index,el){
await writeClipboard(currentPalettes[index].colors.join('\n'));
flashCheck(el,'Palette copied');
}

async function copyLink(slug,el){
const url = window.location.origin + '/palette/' + slug;
await writeClipboard(url);
flashCheck(el,'Palette link copied');
}

function downloadPaletteImage(index,el){
const palette = currentPalettes[index];
const canvas = document.createElement('canvas');
canvas.width = 1200;
canvas.height = 720;
const ctx = canvas.getContext('2d');
ctx.fillStyle = '#ffffff';
ctx.fillRect(0,0,1200,720);
ctx.fillStyle = '#111111';
ctx.font = '800 54px Inter, Arial';
ctx.fillText(palette.name,60,86);
const w = 1080 / palette.colors.length;
palette.colors.forEach((color,i)=>{
ctx.fillStyle = color;
ctx.fillRect(60 + i*w,130,w,360);
ctx.fillStyle = '#111111';
ctx.font = '700 26px Inter, Arial';
ctx.fillText(color,70 + i*w,540);
});
ctx.font = '800 30px Inter, Arial';
ctx.fillText('Color Fiind',60,650);
const link = document.createElement('a');
link.download = palette.slug + '-color-palette.png';
link.href = canvas.toDataURL('image/png');
link.click();
flashCheck(el,'Palette image downloaded');
}

function showToast(message){
copyToast.textContent = message;
copyToast.classList.add('show');
clearTimeout(showToast.timer);
showToast.timer = setTimeout(()=>copyToast.classList.remove('show'),1600);
}

function flashCheck(el,message='Copied'){
const original = el.innerHTML;
el.classList.add('copied-pulse');
el.innerHTML = '✓';
showToast(message);
setTimeout(()=>{
el.innerHTML = original;
el.classList.remove('copied-pulse');
},1200);
}

async function likePalette(slug){
let likedPalettes = getLikedPalettes();
const palette = palettes.find(item => item.slug === slug);
const alreadyLiked = likedPalettes.includes(slug);

if(alreadyLiked){
likedPalettes = likedPalettes.filter(item => item !== slug);
setLikedPalettes(likedPalettes);
if(palette){
palette.likes = Math.max(0,(Number(palette.likes) || 0) - 1);
}
renderInfinite();

try{
const result = await sendUnlikeToServer(slug);
if(palette && typeof result.count !== 'undefined'){
palette.likes = Math.max(0,Number(result.count) || 0);
renderInfinite();
}
}catch(error){
console.warn('Unlike saved locally only because API is not connected yet.',error);
}
return;
}

likedPalettes.push(slug);
setLikedPalettes(likedPalettes);

if(palette){
palette.likes = (Number(palette.likes) || 0) + 1;
}
renderInfinite();

try{
const result = await sendLikeToServer(slug);
if(palette && typeof result.count !== 'undefined'){
palette.likes = Number(result.count) || 0;
renderInfinite();
}
}catch(error){
console.warn('Like saved locally only because API is not connected yet.',error);
}
}

function showFavorites(){
const likedPalettes = getLikedPalettes();
currentPalettes = palettes.filter(palette => likedPalettes.includes(palette.slug));
currentPage = 1;
currentMode = 'favorites';
clearCategoryActive();
searchInput.value = '';
scrollTopAndRender();
closeSidebar();
}

function showAll(){
currentPalettes = [...palettes];
currentPage = 1;
currentMode = 'all';
setCategoryActive('all');
searchInput.value = '';
scrollTopAndRender();
}

function sortPopular(){
currentPalettes = [...palettes].sort((a,b)=>b.likes-a.likes);
currentPage = 1;
currentMode = 'popular';
clearCategoryActive();
searchInput.value = '';
scrollTopAndRender();
}

function shufflePalettes(){
currentPalettes = [...palettes].sort(()=>Math.random()-0.5);
currentPage = 1;
currentMode = 'random';
clearCategoryActive();
searchInput.value = '';
scrollTopAndRender();
}

function filterCategory(category,element){
document.querySelectorAll('.category').forEach(cat=>cat.classList.remove('active'));
element.classList.add('active');

if(category === 'all'){
currentPalettes = [...palettes];
currentMode = 'all';
}else{
currentPalettes = palettes.filter(palette => palette.category === category);
currentMode = category;
}

currentPage = 1;
searchInput.value = '';
scrollTopAndRender();
closeSidebar();
}

function setCategoryActive(category){
document.querySelectorAll('.category').forEach(cat=>{
cat.classList.toggle('active', cat.textContent.trim().toLowerCase() === category.toLowerCase());
});
}

function clearCategoryActive(){
document.querySelectorAll('.category').forEach(cat=>cat.classList.remove('active'));
}

function setActiveNav(element){
document.querySelectorAll('.nav-item').forEach(nav=>nav.classList.remove('active'));
element.classList.add('active');
}

function scrollTopAndRender(){
window.scrollTo({top:0,behavior:'smooth'});
renderInfinite();
}

/* SEARCH ENGINE - simple stable V8-style search */
let searchTimer;

function getSearchBase(){
if(categories.includes(currentMode)){
return palettes.filter(palette => palette.category === currentMode);
}
if(currentMode === 'favorites'){
const likedPalettes = getLikedPalettes();
return palettes.filter(palette => likedPalettes.includes(palette.slug));
}
if(currentMode === 'popular'){
return [...palettes].sort((a,b)=>b.likes-a.likes);
}
if(currentMode === 'random'){
return [...currentPalettes];
}
return [...palettes];
}

searchInput.addEventListener('input',function(){
clearTimeout(searchTimer);
const query = this.value.trim().toLowerCase();

searchTimer = setTimeout(()=>{
const base = getSearchBase();

if(query === ''){
currentPalettes = base;
}else{
currentPalettes = base.filter(palette =>
palette.name.toLowerCase().includes(query) ||
palette.category.toLowerCase().includes(query) ||
(palette.concept || '').toLowerCase().includes(query) ||
palette.colors.join(' ').toLowerCase().includes(query)
);
}

currentPage = 1;
renderInfinite();
},180);
});

/* INFINITE SCROLL */
window.addEventListener('scroll',()=>{
if(isLoading) return;
const nearBottom = window.innerHeight + window.scrollY >= document.body.offsetHeight - 800;
if(nearBottom && (currentPage * itemsPerLoad) < currentPalettes.length){
isLoading = true;
loader.style.display = 'block';
requestAnimationFrame(()=>{
setTimeout(()=>{
currentPage++;
renderInfinite();
loader.style.display = 'none';
isLoading = false;
},120);
});
}
});

/* CARD CLICK: open SEO-friendly backend palette detail page */
document.addEventListener('click',function(e){
const card = e.target.closest('.card');
if(!card) return;
window.location.href = '/palette/' + card.dataset.slug;
});


/* HOVER PREVIEW POSITIONING */
function setupHoverPreviews(){
document.querySelectorAll('.preview-menu,.season-menu').forEach(item=>{
item.addEventListener('mouseenter',()=>{
const rect = item.getBoundingClientRect();
const card = item.querySelector('.preview-card,.season-flyout');
const h = card && card.classList.contains('season-flyout') ? 360 : 182;
let top = rect.top - 20;
if(top + h > window.innerHeight - 16) top = window.innerHeight - h - 16;
if(top < 16) top = 16;
item.style.setProperty('--preview-top', top + 'px');
});
});
}

/* DARK MODE */
function toggleTheme(){
const current = document.documentElement.getAttribute('data-theme');
const btn = document.querySelector('.theme-toggle');

if(current === 'dark'){
document.documentElement.removeAttribute('data-theme');
localStorage.setItem('theme','light');
btn.innerHTML = '🌙 Dark Mode';
}else{
document.documentElement.setAttribute('data-theme','dark');
localStorage.setItem('theme','dark');
btn.innerHTML = '☀️ Light Mode';
}
}

function loadSavedTheme(){
const savedTheme = localStorage.getItem('theme');
const btn = document.querySelector('.theme-toggle');
if(savedTheme === 'dark'){
document.documentElement.setAttribute('data-theme','dark');
btn.innerHTML = '☀️ Light Mode';
}else{
document.documentElement.removeAttribute('data-theme');
btn.innerHTML = '🌙 Dark Mode';
}
}

/* MOBILE SIDEBAR */
function openSidebar(){document.getElementById('sidebar').classList.add('show');document.getElementById('sidebarBackdrop').classList.add('show');document.body.classList.add('sidebar-open');}
function closeSidebar(){document.getElementById('sidebar').classList.remove('show');document.getElementById('sidebarBackdrop').classList.remove('show');document.body.classList.remove('sidebar-open');}
function toggleSidebar(){const sidebar=document.getElementById('sidebar');sidebar.classList.contains('show')?closeSidebar():openSidebar();}

document.addEventListener('click',function(e){
const sidebar = document.getElementById('sidebar');
const toggle = document.querySelector('.mobile-toggle');

if(
window.innerWidth < 1000 &&
sidebar.classList.contains('show') &&
!sidebar.contains(e.target) &&
!toggle.contains(e.target)
){
closeSidebar();
}
});

/* KEYBOARD SHORTCUT LIKE V10 */
document.addEventListener('keydown',e=>{
if(e.key === '/' && document.activeElement !== searchInput){
e.preventDefault();
searchInput.focus();
}
});

/* SCROLL POSITION MEMORY */
if(sessionStorage.getItem('colorfiind-scroll')){
window.scrollTo(0,parseInt(sessionStorage.getItem('colorfiind-scroll')));
}

window.addEventListener('beforeunload',()=>{
sessionStorage.setItem('colorfiind-scroll',window.scrollY);
});

/* INITIAL LOAD */
loadSavedTheme();
setupHoverPreviews();
renderInfinite();
loadGlobalLikes();

console.log('ColorFiind V10 Corrected - V8 Style Loaded');
console.log('Total Palettes:',palettes.length);
</script>

